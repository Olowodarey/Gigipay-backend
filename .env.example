# App
PORT=3001
NODE_ENV=production

# Frontend URL (comma-separated for multiple origins)
FRONTEND_URL=https://yourdomain.com

# Database
DATABASE_URL=postgresql://user:password@host:5432/gigipay

# JWT — use a long random secret in production
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Privy
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Blockchain RPC
CELO_RPC_URL=https://forno.celo.org
BASE_RPC_URL=https://mainnet.base.org

# Nellobytesystems Airtime API
NELLO_USER_ID=
NELLO_API_KEY=
NELLO_CALLBACK_URL=https://your-backend.com/airtime/callback

# CoinGecko (Demo API key — free at coingecko.com/api)
COINGECKO_API_KEY=
